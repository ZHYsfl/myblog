---
import ThemeScript from '@/components/layout/ThemeScript.astro';
import { Header } from '@/components/layout/Header';
import { Footer } from '@/components/layout/Footer';
import { GlobalPlayer } from '@/components/music/GlobalPlayer';
import { SITE } from '@/lib/constants';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  class?: string;
}

const { title, description = SITE.description, class: className } = Astro.props;
const pageTitle = title ? `${title} | ${SITE.authorEn}` : `${SITE.authorEn}`;
---

<!doctype html>
<html lang="zh-CN" data-theme="dark">
  <head>
    <ThemeScript />
    <script is:inline>
      // 在 React 水合前把语言状态同步到 <html>，避免中英文 SSR 不匹配
      (function () {
        const STORAGE_KEY = 'myblog:lang';
        let lang = 'zh';
        try {
          const stored = sessionStorage.getItem(STORAGE_KEY);
          if (stored === 'zh' || stored === 'en') lang = stored;
          else if (location.pathname.includes('/en/')) lang = 'en';
        } catch {
          /* ignore sessionStorage access errors */
        }
        document.documentElement.setAttribute('data-lang', lang);
      })();
    </script>
    <script is:inline>
      // 创建持久音频节点，挂在 <html> 根上，永不参与页面内容替换
      if (!document.getElementById('global-audio')) {
        const audio = document.createElement('audio');
        audio.id = 'global-audio';
        audio.preload = 'metadata';
        audio.style.cssText =
          'position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;';
        document.documentElement.appendChild(audio);
      }
    </script>
    <script is:inline>
      // 极简客户端路由：只替换 <main>，音频/Header/播放器完全不动
      (function () {
        const BASE = '';
        const cache = new Map();
        let pendingPath = '';

        function isInternal(href) {
          try {
            const url = new URL(href, location.href);
            return url.origin === location.origin && url.pathname.startsWith(BASE);
          } catch {
            return false;
          }
        }

        async function fetchHtml(path) {
          const res = await fetch(path);
          if (!res.ok) return null;
          return res.text();
        }

        function prefetch(href) {
          if (!isInternal(href)) return;
          const path = new URL(href, location.href).pathname;
          if (cache.has(path)) return;
          cache.set(
            path,
            fetchHtml(path).catch(() => null)
          );
        }

        async function navigate(href, push = true, force = false) {
          if (!isInternal(href)) {
            location.assign(href);
            return;
          }

          const url = new URL(href, location.href);
          const path = url.pathname;
          if (!force && path === location.pathname) {
            window.scrollTo({ top: 0, behavior: 'instant' });
            return;
          }
          pendingPath = path;

          try {
            let html = cache.get(path);
            if (!html) html = fetchHtml(path);
            cache.set(path, html);

            html = await html;
            if (!html || (!force && pendingPath !== path)) return;

            const parser = new DOMParser();
            const newDoc = parser.parseFromString(html, 'text/html');

            const newMain = newDoc.querySelector('main');
            const oldMain = document.querySelector('main');
            if (!newMain || !oldMain) {
              location.assign(href);
              return;
            }

            // 采用 adoptNode 转移真实节点，确保 astro-island 能正常水合
            // 先卸载 <main> 内的旧 React 岛屿，避免它们的监听和状态残留
            oldMain.querySelectorAll('astro-island').forEach((island) => {
              if (typeof island.unmount === 'function') {
                island.unmount();
              }
            });
            oldMain.replaceChildren(
              ...Array.from(newMain.childNodes).map((node) => document.adoptNode(node))
            );

            document.body.className = newDoc.body.className;

            const newTitle = newDoc.querySelector('title')?.textContent;
            if (newTitle) document.title = newTitle;

            const newDesc = newDoc.querySelector('meta[name="description"]');
            const oldDesc = document.querySelector('meta[name="description"]');
            if (newDesc && oldDesc) {
              oldDesc.setAttribute('content', newDesc.getAttribute('content') || '');
            }

            const newAlternate = newDoc.querySelector('link[rel="alternate"]');
            const oldAlternate = document.querySelector('link[rel="alternate"]');
            if (newAlternate && oldAlternate) {
              oldAlternate.setAttribute('href', newAlternate.getAttribute('href') || '');
              oldAlternate.setAttribute('hreflang', newAlternate.getAttribute('hreflang') || '');
            } else if (newAlternate) {
              document.head.appendChild(document.adoptNode(newAlternate));
            } else if (oldAlternate) {
              oldAlternate.remove();
            }

            window.scrollTo({ top: 0, behavior: 'instant' });
            if (push) history.pushState({}, '', path);

            document.dispatchEvent(new Event('astro:page-load'));
          } catch {
            location.assign(href);
          }
        }

        document.addEventListener('click', (e) => {
          const a = e.target.closest('a');
          if (!a) return;
          if (a.getAttribute('data-astro-reload') || a.target === '_blank' || !isInternal(a.href))
            return;
          e.preventDefault();
          navigate(a.href).catch(() => location.assign(a.href));
        });

        window.addEventListener('popstate', () => navigate(location.href, false, true));

        document.addEventListener(
          'mouseover',
          (e) => {
            const a = e.target.closest('a');
            if (a) prefetch(a.href);
          },
          { passive: true }
        );

        window.__navigate = (href) => navigate(href, true, false);
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Noto+Serif+SC:wght@400;600;700&family=Noto+Sans+SC:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <slot name="head" />
    <script is:inline>
      // 歌曲列表兜底：即使 React 岛屿还没水合，点击也能播放
      document.addEventListener('click', (e) => {
        const btn = e.target.closest('[data-play-index]');
        if (!btn) return;
        const index = Number(btn.getAttribute('data-play-index'));
        if (Number.isNaN(index)) return;
        const api = window.__music;
        if (api && typeof api.play === 'function') {
          api.play(index);
        }
      });
    </script>
  </head>
  <body class:list={['pb-24', className]}>
    <Header client:load />
    <main>
      <slot />
    </main>
    <Footer client:load />
    <GlobalPlayer client:load />
  </body>
</html>
