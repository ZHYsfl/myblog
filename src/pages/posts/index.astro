---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { PostArchive } from '@/components/post/PostArchive';
import { getCollection } from 'astro:content';
import type { CategoryId } from '@/lib/constants';

const rawPosts = await getCollection('posts');
const posts = rawPosts.map((p) => ({
  data: {
    title: p.data.title,
    date: p.data.date.toISOString(),
    category: p.data.category as CategoryId,
    description: p.data.description,
    slug: p.data.slug,
    lang: p.data.lang as 'zh' | 'en',
  },
}));
---

<BaseLayout title="文章" description="周浩洋的数字花园，按年份整理的文章存档。">
  <PostArchive posts={posts} client:load />
</BaseLayout>
